rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PUBLIC READ/WRITE for this specific document 
    // This allows our PIN-based frontend to mutation data from Vercel
    // WARNING: For private store projects only.
    match /store/{docId} {
      allow read, write: if docId == 'main_store_data' || docId == 'main_site_settings';
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
