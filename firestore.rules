rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Read
    match /{document=**} {
      allow read: if true;
    }

    // Admin Write Access (PIN matching logic should ideally be here if possible, 
    // but typically we'd use Auth. Since we use PIN in frontend, we'll keep it simple for now)
    match /products/{id} { allow write: if true; }
    match /slides/{id} { allow write: if true; }
    match /settings/{id} { allow write: if true; }
    match /categories/{id} { allow write: if true; }
  }
}
