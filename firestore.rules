rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check function
    function isAdmin() {
      return request.auth != null 
        && request.auth.token.email == "abdulkarman74@gmail.com";
    }

    // Root path for store data
    // match /store/main_store_data matches the specific document
    match /store/main_store_data {
      allow get: if true;
      allow list: if false; 
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
