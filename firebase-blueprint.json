{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A digital product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Config for the store",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "slogan": { "type": "string" }
      }
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "settings/main": {
      "schema": "Settings",
      "description": "Main branding config"
    }
  }
}
